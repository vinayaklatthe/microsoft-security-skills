{
  "name": "microsoft-security-skills",
  "version": "0.1.0",
  "description": "Validation harness for the Microsoft Security skills repository.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "check:structure": "node validation/check-structure.mjs",
    "check:links": "node validation/check-links.mjs",
    "eval": "node validation/run-evals.mjs",
    "eval:report": "node validation/run-evals.mjs --report",
    "eval:answers": "node validation/run-evals.mjs --answers --dir validation/answers/with-skill",
    "eval:answers:report": "node validation/run-evals.mjs --answers --dir validation/answers/with-skill --report",
    "eval:compare": "node validation/compare-evals.mjs",
    "eval:compare:report": "node validation/compare-evals.mjs --report",
    "validate": "npm run check:structure && npm run eval && npm run check:links"
  }
}
